    {
      "id": "taylor",
      "label": "Taylorreeksen",
      "points": 15,
      "difficulty": "gemiddeld",
      "reference_style": "bereken Taylorreeksen door substitutie of differentiatie, dan term-voor-term integreren. Indien standaard reeksen bekend zijn kunnen deze direct gebruikt worden, anders afleiden via Taylor formule",
      "required_skills": {
        "calculus": ["differentiatie", "integratie", "reeksontwikkeling", "limieten"],
        "algebra": ["substitutie", "patroonherkenning", "term_manipulatie"]
      },
      "common_functions": [
        "sin(u)", "cos(u)", "e^u", "ln(1+u)", "1/(1+u)", "(1+u)^n"
      ],
      "typical_substitutions": [
        "u = x^2", "u = -x", "u = -x^2", "u = 2x"
      ],
      "exercise_patterns": [
        {
          "pattern_type": "substitutie_gebaseerd",
          "structure": "Gegeven functie f(x) met bekend reekspatroon",
          "steps": [
            "Schrijf bekende Taylorreeks voor basisfunctie op (indien bekend) of leid af",
            "Pas substitutie u = g(x) toe",
            "Breek af bij opgegeven macht",
            "Optioneel: integreer term voor term"
          ],
          "point_distribution": {
            "bekende_reeks": 3,
            "substitutie": 4,
            "afbreking": 3,
            "integratie": 5
          },
          "examples": ["sin(x^2)", "cos(x^2)", "e^(-x^2)", "ln(1+x^2)"],
          "instruction_note": "Studenten mogen bekende standaard reeksen direct gebruiken indien deze bekend zijn, anders afleiden via Taylor formule",
          "solution_note": "In uitwerkingen moet altijd vermeld worden dat als studenten de gebruikte standaard reeks niet kennen, ze deze kunnen afleiden via herhaalde differentiatie en de Taylor formule"
        },
        {
          "pattern_type": "differentiatie_gebaseerd",
          "structure": "Functies die herhaalde differentiatie vereisen",
          "steps": [
            "Bereken afgeleiden f', f'', f''', f''''",
            "Evalueer in x = 0",
            "Pas Taylor formule toe",
            "Optioneel: integreer"
          ],
          "point_distribution": {
            "afgeleiden": 4,
            "evaluatie": 3,
            "formule_toepassing": 3,
            "integratie": 5
          },
          "examples": ["sqrt(1+x^2)", "1/sqrt(1+x^2)"]
